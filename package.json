    "@tailwindcss/cli": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1"
  },
  "dependencies": {
    "alpinejs": "^3.15.12"
  }
}
