  "main": "index.js",
  "scripts": {
    "js:watch": "npx esbuild ./assets/js/main.js --bundle --outfile=./assets/dist/main.js --platform=browser --format=iife --watch",
    "css:watch": "npx @tailwindcss/cli -i ./assets/css/main.css -o ./assets/dist/main.css --watch",
    "build": "npx esbuild ./assets/js/main.js --bundle --outfile=./assets/dist/main.js --platform=browser --format=iife --minify && npx @tailwindcss/cli -i ./assets/css/main.css -o ./assets/dist/main.css --minify"
  },
  "keywords": [],
